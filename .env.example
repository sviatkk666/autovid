# Copy to .env and fill what you use. Leave blank to skip a provider.

# --- Hosting / storage (all optional; sensible local defaults) ---
# Where writable studio data lives (channels, projects, media, RAG memory).
# Defaults to the repo root locally; set to a mounted volume on a host with an
# ephemeral filesystem (e.g. Railway: DATA_DIR=/data).
# DATA_DIR=/data
# Metadata store. Unset = JSON files under DATA_DIR. Set = PostgreSQL (channel +
# project documents in JSONB; media still lives on DATA_DIR). Railway injects it.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Optional demo-data bundle (tar.gz of channels/ + projects/) fetched into
# DATA_DIR on first boot; see scripts/make_seed_bundle.sh.
# SEED_URL=https://.../autovid-demo-seed.tar.gz

# Cloud LLM (best quality)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local LLM via Ollama (free). Default URL shown.
OLLAMA_HOST=http://localhost:11434

# TTS (cloud voices)
ELEVENLABS_API_KEY=

# ai33.pro — image-generation gateway (Imagen-style), images.generate.provider=ai33.
# NOTE: its TTS is images-only now (public v1 voice sunset, v3 needs a session
# token), so ai33 is never auto-selected for voice — use ElevenLabs or Piper.
AI33_API_KEY=
# AI33_BASE_URL=https://api.ai33.pro   # override only if needed

# Images (search/download) — all optional.
# Openverse / Wikimedia / Internet Archive need no key.
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Images (AI generation) — all optional. OpenAI reuses OPENAI_API_KEY above.
REPLICATE_API_TOKEN=        # Flux via Replicate
STABILITY_API_KEY=          # Stability AI (Stable Image)
SD_WEBUI_URL=http://localhost:7860   # local Stable Diffusion WebUI (AUTOMATIC1111/Forge)

# --- Autoposting bridge to the YouTube-Farm CRM (push-channel / push) ---
# The CRM consumes prepared channels + videos. autovid uploads assets to R2 and
# POSTs metadata to the CRM. The x-service-token (AUTOVID_SERVICE_TOKEN) must
# match the CRM's env. All optional unless you use `push-channel` / `push`.
CRM_BASE_URL=               # e.g. https://crm.example.com
AUTOVID_SERVICE_TOKEN=      # shared secret, >=16 chars (same value in the CRM)

# Cloudflare R2 (S3-compatible) — where mp4/thumbnails/avatar/banner are stored.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=yt-farm-assets
R2_PUBLIC_URL=              # public base, e.g. https://assets.example.com (custom domain or r2.dev)
